{
  "name": "@platforma-open/milaboratories.sequence-properties",
  "version": "1.4.0",
  "scripts": {
    "build": "shx rm -rf ./block-pack && block-tools pack",
    "mark-stable": "block-tools mark-stable -r 's3://milab-euce1-prod-pkgs-s3-block-registry/pub/releases/?region=eu-central-1'",
    "prepublishOnly": "block-tools pack && block-tools publish --unstable -r 's3://milab-euce1-prod-pkgs-s3-block-registry/pub/releases/?region=eu-central-1'",
    "do-pack": "shx rm -f *.tgz && block-tools pack && pnpm pack && shx mv *.tgz package.tgz"
  },
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "dependencies": {
    "@platforma-sdk/model": "catalog:",
    "@platforma-open/milaboratories.sequence-properties.workflow": "workspace:*",
    "@platforma-open/milaboratories.sequence-properties.model": "workspace:*",
    "@platforma-open/milaboratories.sequence-properties.ui": "workspace:*"
  },
  "block": {
    "components": {
      "workflow": "@platforma-open/milaboratories.sequence-properties.workflow/dist/tengo/tpl/main.plj.gz",
      "model": "@platforma-open/milaboratories.sequence-properties.model/dist/model.json",
      "ui": "@platforma-open/milaboratories.sequence-properties.ui/dist"
    },
    "meta": {
      "title": "Sequence Properties",
      "logo": "file:../logos/block-logo.png",
      "url": "https://github.com/platforma-open/sequence-properties",
      "support": "mailto:support@milaboratories.com",
      "description": "Compute physico-chemical properties (charge, pI, GRAVY, MW, extinction coefficient, instability/aliphatic indices, aromaticity) for peptides and antibody/TCR sequences.",
      "longDescription": "file:../docs/description.md",
      "changelog": "file:./CHANGELOG.md",
      "tags": [
        "airr",
        "antibody",
        "peptide",
        "downstream"
      ],
      "organization": {
        "name": "MiLaboratories Inc",
        "url": "https://milaboratories.com/",
        "logo": "file:../logos/organization-logo.png"
      }
    }
  },
  "devDependencies": {
    "@platforma-sdk/block-tools": "catalog:"
  },
  "packageManager": "pnpm@9.15.0"
}
